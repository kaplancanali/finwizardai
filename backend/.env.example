# FinVis - Financial Risk Analysis API Configuration

# API Settings
API_TITLE=FinVis Financial Risk Analysis API
API_VERSION=1.0.0
API_DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# NLP Model Settings
SENTIMENT_MODEL=savasy/bert-base-turkish-cased-sentiment

# Scraper Settings
KAP_BASE_URL=https://www.kap.org.tr
# Optional: {"TUPRS":"123-tupras-turkiye-petrol-rafinerileri-a-s"} — see backend/data/kap_ozet_slugs.json
# KAP_OZET_SLUG_OVERRIDES_JSON=
REQUEST_TIMEOUT=30
MAX_DISCLOSURES=10
MAX_NEWS_ARTICLES=10

# Cache Settings
CACHE_TTL_SECONDS=300

# Risk Engine Settings
KAP_WEIGHT=0.5
NEWS_WEIGHT=0.3
SENTIMENT_WEIGHT=0.2

# Risk Thresholds
RISK_LOW_THRESHOLD=30
RISK_MEDIUM_THRESHOLD=50
RISK_HIGH_THRESHOLD=70

# Logging
LOG_LEVEL=INFO
